# ============================================
# SyncSphere Backend Environment Variables
# Copy to .env and fill in your values
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK
# Download service account JSON from Firebase Console > Project Settings > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Cloud SQL (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=syncsphere
DB_USER=postgres
DB_PASSWORD=your-db-password
# For Cloud Run with Cloud SQL Auth Proxy:
# DB_SOCKET_PATH=/cloudsql/your-project:us-central1:syncsphere-db

# Google Cloud Storage
GCS_BUCKET_NAME=syncsphere-files

# BigQuery
BQ_DATASET=syncsphere_analytics

# Vertex AI
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# Google Calendar API (optional)
GOOGLE_CALENDAR_ENABLED=false
