# ============================================
# SyncSphere Backend Environment Variables
# GCP Project: redwindow-482406
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK — uses Application Default Credentials
# On Cloud Run this is automatic. Locally, run:
#   gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=redwindow-482406

# Cloud SQL (PostgreSQL) — GCP Project: redwindow-482406
DB_HOST=localhost
DB_PORT=5432
DB_NAME=syncsphere
DB_USER=postgres
DB_PASSWORD=SyncSphere2026!
# For Cloud Run with Cloud SQL Auth Proxy:
# DB_SOCKET_PATH=/cloudsql/redwindow-482406:us-central1:syncsphere-db

# Google Cloud Storage — GCP Project: redwindow-482406
GCS_BUCKET_NAME=redwindow-482406-syncsphere-files

# BigQuery — GCP Project: redwindow-482406
BQ_DATASET=syncsphere_analytics

# Vertex AI — GCP Project: redwindow-482406
VERTEX_AI_PROJECT=redwindow-482406
VERTEX_AI_LOCATION=us-central1

# Google Calendar API (optional)
GOOGLE_CALENDAR_ENABLED=false
